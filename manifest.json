{
  "manifest_version": 3,
  "name": "DL Path Manager",
  "version": "0.1.1",
  "description": "Recent Firefox downloads list with quick path, URL, and table copy actions.",
  "permissions": [
    "downloads",
    "downloads.open",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "DL Path Manager",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-dl-path-manager@example.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "142.0"
    }
  }
}
